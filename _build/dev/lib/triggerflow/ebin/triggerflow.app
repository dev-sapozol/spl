{application,triggerflow,
    [{compile_env,
         [{triggerflow,
              ['Elixir.TriggerflowWeb.Endpoint',code_reloader],
              {ok,true}},
          {triggerflow,
              ['Elixir.TriggerflowWeb.Endpoint',debug_errors],
              {ok,true}},
          {triggerflow,['Elixir.TriggerflowWeb.Endpoint',force_ssl],error},
          {triggerflow,['Elixir.TriggerflowWeb.Gettext'],error}]},
     {optional_applications,[]},
     {applications,
         [kernel,stdlib,elixir,logger,runtime_tools,phoenix,phoenix_ecto,
          ecto_sql,postgrex,phoenix_live_dashboard,swoosh,req,
          telemetry_metrics,telemetry_poller,gettext,jason,dns_cluster,bandit,
          phoenix_pubsub,phoenix_view,absinthe,absinthe_plug,absinthe_phoenix,
          guardian,jose,myxql,dotenvy,dataloader,ex_aws_sqs,ex_aws,ex_aws_s3,
          poison,elixir_uuid,sweet_xml,timex,iconv,ex_aws_ses,mail,
          bcrypt_elixir,cors_plug]},
     {description,"triggerflow"},
     {modules,
         ['Elixir.Triggerflow','Elixir.Triggerflow.Account',
          'Elixir.Triggerflow.Account.User','Elixir.Triggerflow.Application',
          'Elixir.Triggerflow.Auth.Authentication',
          'Elixir.Triggerflow.Auth.Guardian',
          'Elixir.Triggerflow.Auth.Guardian.Plug',
          'Elixir.Triggerflow.AwsBuilder','Elixir.Triggerflow.EmailsResolver',
          'Elixir.Triggerflow.InboxEmail',
          'Elixir.Triggerflow.InboxEmail.EmailComposer',
          'Elixir.Triggerflow.InboxEmail.UtilsFunctions',
          'Elixir.Triggerflow.MailBox','Elixir.Triggerflow.MailBox.Emails',
          'Elixir.Triggerflow.MailBox.SystemFolders',
          'Elixir.Triggerflow.MailBox.UserFolders',
          'Elixir.Triggerflow.Mailer','Elixir.Triggerflow.ParseMail',
          'Elixir.Triggerflow.ParseMail.Attachment',
          'Elixir.Triggerflow.ParseMail.Body',
          'Elixir.Triggerflow.ParseMail.Email',
          'Elixir.Triggerflow.ParseMail.Headers',
          'Elixir.Triggerflow.ParseMail.Validators','Elixir.Triggerflow.Repo',
          'Elixir.Triggerflow.Role',
          'Elixir.Triggerflow.SystemFoldersResolver',
          'Elixir.Triggerflow.UserFoldersResolver',
          'Elixir.Triggerflow.UserResolver','Elixir.TriggerflowWeb',
          'Elixir.TriggerflowWeb.AuthController',
          'Elixir.TriggerflowWeb.Context','Elixir.TriggerflowWeb.Endpoint',
          'Elixir.TriggerflowWeb.ErrorJSON','Elixir.TriggerflowWeb.Gettext',
          'Elixir.TriggerflowWeb.PageController',
          'Elixir.TriggerflowWeb.Router','Elixir.TriggerflowWeb.Schema',
          'Elixir.TriggerflowWeb.Schema.Compiled',
          'Elixir.TriggerflowWeb.Schema.Emails',
          'Elixir.TriggerflowWeb.Schema.Middleware.Authenticate',
          'Elixir.TriggerflowWeb.Schema.Middleware.ChangesetErrors',
          'Elixir.TriggerflowWeb.Schema.Scalars',
          'Elixir.TriggerflowWeb.Schema.SystemFolders',
          'Elixir.TriggerflowWeb.Schema.User',
          'Elixir.TriggerflowWeb.Schema.UserFolders',
          'Elixir.TriggerflowWeb.Telemetry']},
     {registered,[]},
     {vsn,"0.1.0"},
     {mod,{'Elixir.Triggerflow.Application',[]}}]}.
