{application,spl,
             [{compile_env,[{spl,['Elixir.SplWeb.Endpoint',code_reloader],
                                 {ok,true}},
                            {spl,['Elixir.SplWeb.Endpoint',debug_errors],
                                 {ok,true}},
                            {spl,['Elixir.SplWeb.Endpoint',force_ssl],error},
                            {spl,['Elixir.SplWeb.Gettext'],error}]},
              {optional_applications,[]},
              {applications,[kernel,stdlib,elixir,logger,runtime_tools,
                             phoenix,phoenix_ecto,ecto_sql,postgrex,
                             phoenix_live_dashboard,swoosh,req,
                             telemetry_metrics,telemetry_poller,gettext,jason,
                             dns_cluster,bandit,phoenix_pubsub,phoenix_view,
                             absinthe,absinthe_plug,absinthe_phoenix,guardian,
                             jose,myxql,dotenvy,dataloader,ex_aws_sqs,ex_aws,
                             ex_aws_s3,poison,elixir_uuid,sweet_xml,timex,
                             iconv,ex_aws_ses,mail,bcrypt_elixir,cors_plug]},
              {description,"spl"},
              {modules,['Elixir.Spl','Elixir.Spl.Account',
                        'Elixir.Spl.Account.User','Elixir.Spl.Application',
                        'Elixir.Spl.Auth.Authentication',
                        'Elixir.Spl.Auth.Guardian',
