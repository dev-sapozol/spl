                        'Elixir.Spl.InboxEmail.UtilsFunctions',
                        'Elixir.Spl.MailBox','Elixir.Spl.MailBox.Emails',
                        'Elixir.Spl.MailBox.SystemFolders',
                        'Elixir.Spl.MailBox.UserFolders','Elixir.Spl.Mailer',
                        'Elixir.Spl.ParseMail',
                        'Elixir.Spl.ParseMail.Attachment',
                        'Elixir.Spl.ParseMail.Body',
                        'Elixir.Spl.ParseMail.Email',
                        'Elixir.Spl.ParseMail.Headers',
                        'Elixir.Spl.ParseMail.Validators','Elixir.Spl.Repo',
                        'Elixir.Spl.Role','Elixir.Spl.SystemFoldersResolver',
                        'Elixir.Spl.UserFoldersResolver',
                        'Elixir.Spl.UserResolver','Elixir.SplWeb',
                        'Elixir.SplWeb.AuthController',
                        'Elixir.SplWeb.Context','Elixir.SplWeb.Endpoint',
                        'Elixir.SplWeb.ErrorJSON','Elixir.SplWeb.Gettext',
                        'Elixir.SplWeb.PageController','Elixir.SplWeb.Router',
                        'Elixir.SplWeb.Schema',
                        'Elixir.SplWeb.Schema.Compiled',
                        'Elixir.SplWeb.Schema.Emails',
                        'Elixir.SplWeb.Schema.Middleware.Authenticate',
                        'Elixir.SplWeb.Schema.Middleware.ChangesetErrors',
                        'Elixir.SplWeb.Schema.Scalars',
                        'Elixir.SplWeb.Schema.SystemFolders',
                        'Elixir.SplWeb.Schema.User',
                        'Elixir.SplWeb.Schema.UserFolders',
                        'Elixir.SplWeb.Telemetry']},
              {registered,[]},
              {vsn,"0.1.0"},
              {mod,{'Elixir.Spl.Application',[]}}]}.
